<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_blue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="@color/white"
        android:contentDescription="Back"
        app:layout_constraintTop_toTopOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="64dp"
        android:text="@string/file_saved_title"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rowCongrats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivCongratsCheck"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_congrats_check"
            android:src="@drawable/ic_check"
            android:padding="10dp"
            android:contentDescription="@null"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvCongratsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/congrats_title"
            android:textColor="@color/text_dark"
            android:textStyle="bold"
            android:textSize="17sp"
            app:layout_constraintTop_toTopOf="@id/ivCongratsCheck"
            app:layout_constraintStart_toEndOf="@id/ivCongratsCheck"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvCongratsDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:text="@string/congrats_desc"
            android:textColor="@color/text_gray"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/tvCongratsTitle"
            app:layout_constraintStart_toEndOf="@id/ivCongratsCheck"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rowFileInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/rowCongrats"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivFileIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_file_icon"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            app:tint="@color/text_gray"
            android:padding="10dp"
            android:contentDescription="@null"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="@color/text_dark"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="middle"
            app:layout_constraintTop_toTopOf="@id/ivFileIcon"
            app:layout_constraintBottom_toBottomOf="@id/ivFileIcon"
            app:layout_constraintStart_toEndOf="@id/ivFileIcon"
            app:layout_constraintEnd_toStartOf="@id/tvFileSize" />

        <TextView
            android:id="@+id/tvFileSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_gray"
            android:textSize="13sp"
            app:layout_constraintTop_toTopOf="@id/ivFileIcon"
            app:layout_constraintBottom_toBottomOf="@id/ivFileIcon"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageButton
            android:id="@+id/btnPlaySaved"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="12dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_play"
            app:tint="@color/primary_blue"
            android:contentDescription="Play"
            app:layout_constraintTop_toBottomOf="@id/ivFileIcon"
            app:layout_constraintStart_toStartOf="parent" />

        <SeekBar
            android:id="@+id/seekBarSaved"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:progressTint="@color/primary_blue"
            android:thumbTint="@color/primary_blue"
            app:layout_constraintTop_toTopOf="@id/btnPlaySaved"
            app:layout_constraintBottom_toBottomOf="@id/btnPlaySaved"
            app:layout_constraintStart_toEndOf="@id/btnPlaySaved"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvCurrentSaved"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="00:00:00"
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/btnPlaySaved"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvTotalSaved"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="00:00:00"
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/btnPlaySaved"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tvExploreMore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:layout_marginStart="20dp"
        android:text="@string/explore_more"
        android:textColor="@color/text_dark"
        android:textStyle="bold"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/rowFileInfo"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rowExplore"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvExploreMore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/btnExploreSavedFiles"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnExploreShare">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_explore_circle_blue"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/white"
                android:padding="14dp"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/explore_saved_files"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:textSize="11sp"
                android:gravity="center" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnExploreShare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnExploreSavedFiles"
            app:layout_constraintEnd_toStartOf="@id/btnExploreChange">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_explore_circle_green"
                android:src="@android:drawable/ic_menu_share"
                app:tint="@color/white"
                android:padding="14dp"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/explore_share"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:textSize="11sp"
                android:gravity="center" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnExploreChange"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnExploreShare"
            app:layout_constraintEnd_toStartOf="@id/btnExploreHome">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_explore_circle_purple"
                android:src="@android:drawable/ic_menu_rotate"
                app:tint="@color/white"
                android:padding="14dp"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/explore_change"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:textSize="11sp"
                android:gravity="center" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnExploreHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnExploreChange"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_explore_circle_lightgreen"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/white"
                android:padding="14dp"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/explore_home"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:textSize="11sp"
                android:gravity="center" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>