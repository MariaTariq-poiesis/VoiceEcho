<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:background="@drawable/bg_effect_card"
    android:padding="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/ivAvatar"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_avatar_circle"
        android:padding="12dp"
        android:contentDescription="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/ivCrown"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/bg_crown_badge"
        android:src="@drawable/ic_crown"
        android:padding="3dp"
        android:contentDescription="@null"
        app:layout_constraintTop_toTopOf="@id/ivAvatar"
        app:layout_constraintEnd_toEndOf="@id/ivAvatar"
        android:layout_marginTop="-6dp"
        android:layout_marginEnd="-6dp" />

    <ImageView
        android:id="@+id/ivSelectedCheck"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/bg_check_badge"
        android:src="@drawable/ic_check"
        android:padding="3dp"
        android:contentDescription="@null"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/ivAvatar"
        app:layout_constraintEnd_toEndOf="@id/ivAvatar"
        android:layout_marginTop="-6dp"
        android:layout_marginEnd="-6dp" />

    <TextView
        android:id="@+id/tvEffectName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/text_dark"
        android:textStyle="bold"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/ivAvatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>