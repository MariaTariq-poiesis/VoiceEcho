<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/itemRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_saved_item"
    android:padding="14dp">

    <ImageButton
        android:id="@+id/btnItemPlay"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_purple_circle"
        android:src="@android:drawable/ic_media_play"
        android:scaleType="centerInside"
        android:padding="10dp"
        android:contentDescription="Play"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvItemName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textColor="@color/text_dark"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="middle"
        app:layout_constraintTop_toTopOf="@id/btnItemPlay"
        app:layout_constraintStart_toEndOf="@id/btnItemPlay"
        app:layout_constraintEnd_toStartOf="@id/btnItemMore" />

    <TextView
        android:id="@+id/tvItemMeta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_gray"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tvItemName"
        app:layout_constraintStart_toEndOf="@id/btnItemPlay"
        app:layout_constraintEnd_toStartOf="@id/btnItemMore" />

    <ImageButton
        android:id="@+id/btnItemMore"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@android:color/transparent"
        android:src="@android:drawable/ic_menu_more"
        app:tint="@color/text_gray"
        android:contentDescription="More options"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>